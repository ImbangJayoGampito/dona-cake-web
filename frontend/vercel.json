{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-railway-url.railway.app/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://your-backend-railway-url.railway.app/storage/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
