{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dona-cake-web-production.up.railway.app/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://dona-cake-web-production.up.railway.app/storage/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
